  m_IsActive: 1
--- !u!114 &2064010850
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2064010849}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b3084848c5897dd41b9239769188f1bd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  npcName: PENNY STERLING
  conversation:
  - characterName: DETECTIVE
    sentence: Hi. Don't think we've been introduced.
    isItalic: 0
  - characterName: PENNY STERLING
    sentence: "Penny. I work the front desk, greet guests, hold the door open \u2014
      that kind of thing. I know a lot of people, but what I don't know is why you're
      here."
    isItalic: 0
  - characterName: DETECTIVE
    sentence: Max invited me. Something about honoring my contribution to his archives.
    isItalic: 0
  - characterName: PENNY STERLING
    sentence: Max doesn't honor anyone unless there's something in it for Max. So
      what does he want from you?
    isItalic: 0
  - characterName: DETECTIVE
    sentence: I genuinely don't know.
    isItalic: 0
  - characterName: DETECTIVE
    sentence: "And judging by tonight, I\u2019m not the only one in the dark."
    isItalic: 0
  - characterName: PENNY STERLING
    sentence: "Two years I've been working the front of this place. Not exactly a
      career defining job but it paid the bills. And he couldn't even tell us beforehand.
      Just\u2026 surprise! You\u2019re done!"
    isItalic: 0
  - characterName: PENNY STERLING
    sentence: Now I'm not even sure how I'm going to pay my rent next week.
    isItalic: 0
  - characterName: DETECTIVE
    sentence: Are you going to be okay?
    isItalic: 0
  - characterName: PENNY STERLING
    sentence: I'll find something else. It's just, I don't know.
    isItalic: 0
  - characterName: DETECTIVE
    sentence: 'She seems upset. I should leave her alone.

'
    isItalic: 1
  repeatLine:
    characterName: DETECTIVE
    sentence: "She seems upset. I should leave her alone.\r"
    isItalic: 1
  hasTalked: 0
